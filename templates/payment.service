cat > templates/payment.service << 'EOF'
[Unit]
Description = Payment Service

[Service]
User=roboshop
Environment=CART_HOST=cart.durgagopalakrishna.online
Environment=CART_PORT=8080
Environment=USER_HOST=user.durgagopalakrishna.online
